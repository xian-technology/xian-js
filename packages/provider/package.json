{
  "name": "@xian-tech/provider",
  "version": "0.1.12-beta.2",
  "description": "Xian browser wallet provider contract and reference provider",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xian-technology/xian-js.git",
    "directory": "packages/provider"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
