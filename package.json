{
  "name": "xian-js",
  "version": "0.1.6",
  "private": true,
  "description": "Official JavaScript / TypeScript SDK workspace for Xian",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xian-technology/xian-js.git"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "validate": "npm run typecheck && npm run build && npm run test"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "typescript": "^5.6.3",
    "vitest": "^4.1.1"
  }
}
